# ============================================================
#  PTMA Monitor — Environment Variables
#  Salin file ini: cp .env.example .env
#  Isi nilai sesuai konfigurasi server/hosting Anda.
#  JANGAN commit file .env ke Git!
# ============================================================

# ── Domain ──────────────────────────────────────────────────
# Subdomain backend API Django (tanpa https://)
# Ditulis di DJANGO_ALLOWED_HOSTS agar Django mau melayani request
API_DOMAIN=api.domain-anda.com

# ── Django ───────────────────────────────────────────────────
# Generate secret key baru: https://djecrety.ir/
DJANGO_SECRET_KEY=ganti-dengan-secret-key-acak-yang-panjang-dan-unik!

# DEBUG wajib False di production
DJANGO_DEBUG=False

# Host yang diizinkan (pisah koma, tanpa spasi)
DJANGO_ALLOWED_HOSTS=api.domain-anda.com,localhost,127.0.0.1

# ── Database MySQL ───────────────────────────────────────────
# Format nama di cPanel: cpanelusername_namadb
DB_NAME=usercpanel_ptmadb
DB_USER=usercpanel_ptmauser
DB_PASSWORD=password_database_anda
DB_HOST=localhost
DB_PORT=3306

# ── Database Sumber Data (opsional — DB kedua untuk import data) ─
SDB_NAME=usercpanel_sifoo
SDB_USER=usercpanel_sifoouser
SDB_PASSWORD=password_sifoo
SDB_HOST=localhost
SDB_PORT=3306

# ── CORS — Domain frontend yang boleh mengakses API ──────────
# Pisah koma, tanpa spasi, sertakan https://
# Tambah http://localhost:4200 untuk testing lokal
CORS_ALLOWED_ORIGINS=https://pt.domain-anda.com,https://app.domain-anda.com
