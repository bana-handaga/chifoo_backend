# ============================================================
#  PTMA Monitor — Production Environment Variables
#  Salin file ini menjadi .env lalu isi dengan data hosting Anda
#  JANGAN commit file .env ke Git!
# ============================================================

# Generate secret key baru di: https://djecrety.ir/
DJANGO_SECRET_KEY=ganti-dengan-secret-key-acak-yang-panjang-dan-unik!

# Domain API Anda (tanpa https://)
DJANGO_ALLOWED_HOSTS=api.ptma-monitor.com,localhost

# MySQL (dari cPanel > MySQL Databases)
# Format nama: cpanelusername_namadb
DB_NAME=usercpanel_ptmadb
DB_USER=usercpanel_ptmauser
DB_PASSWORD=password_database_anda
DB_HOST=localhost
DB_PORT=3306

# URL frontend Angular (dengan https://)
CORS_ALLOWED_ORIGINS=https://app.ptma-monitor.com,https://ptma-monitor.com
